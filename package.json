{
  "name": "bwiki",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:web": "npm run docs:generate && vite",
    "dev": "npm run docs:generate && concurrently \"npm:server:dev\" \"vite\"",
    "build": "npm run docs:generate && tsc && vite build",
    "docs:generate": "tsx scripts/docs/generate-docs-artifacts.ts",
    "build:public": "npm run build",
    "preview": "vite preview",
    "server:dev": "tsx watch server/index.ts",
    "server:start": "tsx server/index.ts",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "devDependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@mantine/core": "^9.0.1",
    "@mantine/hooks": "^9.0.1",
    "@mantine/notifications": "^9.0.1",
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@tabler/icons-react": "^3.41.1",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "fuse.js": "^7.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  }
}
